# ---------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ---------------------------------------------------------------

# Socrata API
# Get a free app token at: https://data.cityofnewyork.us/profile/app_tokens
SOCRATA_APP_TOKEN=your_socrata_app_token_here

# Google Cloud Platform
# Your GCP project ID (find it in the GCP console)
GCP_PROJECT_ID=your_gcp_project_id_here

# GCS bucket name (must be globally unique — e.g. nyc-311-yourname-2024)
GCS_BUCKET_NAME=your_gcs_bucket_name_here

# GCS folder prefix for 311 data
GCS_PREFIX=nyc_311

# BigQuery
# Dataset for raw data (external tables pointing at GCS)
BIGQUERY_RAW_DATASET=nyc_311_raw

# Dataset for transformed/production data (dbt outputs)
BIGQUERY_PROD_DATASET=nyc_311_prod

# GCP region (should match where your GCS bucket and BQ datasets are)
GCP_REGION=us-east1

# Path to your GCP service account key JSON file (local path only)
# Generate at: GCP Console > IAM > Service Accounts > Keys
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
